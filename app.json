{
  "expo": {
    "name": "Trustpay",
    "slug": "Trustpay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Trustpay.png",
    "scheme": "trustpay",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/Trustpay.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Trustpay.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/Trustpay.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#3B6EFF"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TrustPay to access your photos to upload ID documents.",
          "cameraPermission": "Allow TrustPay to access your camera to take photos of your ID."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
